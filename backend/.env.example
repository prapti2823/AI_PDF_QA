# ─────────────────────────────────────────────
#  AI PDF QA — Environment Variables
# ─────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  Never commit the actual .env file to version control.
# ─────────────────────────────────────────────

# ── Optional: OpenAI (leave blank to use the free Hugging Face model) ──
OPENAI_API_KEY=

# ── Hugging Face (optional — needed only for private/gated models) ──
HUGGINGFACE_API_KEY=

# ── Embedding model (Sentence Transformers — runs locally, no key needed) ──
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── QA model ──
# Free local model (default — no API key required):
QA_MODEL=deepset/roberta-base-squad2
# Alternatively, use a Hugging Face Inference API model:
# QA_MODEL=deepset/roberta-large-squad2

# ── Text splitting ──
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Upload settings ──
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

# ── Server ──
HOST=0.0.0.0
PORT=8000
